# MongoDB — pick ONE:
# • Dev without installing Mongo: USE_MEMORY_DB=1 (requires: cd server && npm install)
# • Local MongoDB: USE_MEMORY_DB=0 and set MONGODB_URI below
# • Atlas: USE_MEMORY_DB=0 and set MONGODB_URI to your mongodb+srv string
USE_MEMORY_DB=1
# MONGODB_URI=mongodb://127.0.0.1:27017/eco_volunteer

# JWT Secret (required)
JWT_SECRET=your_super_secret_jwt_key_change_this

# Email Configuration (Required for organizer/admin notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@ecovolunteer.com

# Server Port
PORT=4000
